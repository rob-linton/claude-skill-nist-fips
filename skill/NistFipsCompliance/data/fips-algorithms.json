{
  "$schema": "../../../tools/schemas/fips-algorithms.schema.json",
  "source": {
    "name": "Hand-curated from FIPS 140-3 IG and SP 800-131A Rev 3",
    "urls": [
      "https://csrc.nist.gov/projects/cryptographic-module-validation-program/fips-140-3-standards",
      "https://csrc.nist.gov/pubs/sp/800/131/a/r3/final",
      "https://csrc.nist.gov/pubs/sp/800/57/pt1/r5/final"
    ],
    "last_reviewed": "2026-04-20"
  },
  "notice": "Approved status applies at the standard level. Only a CMVP-certified module is FIPS-validated. Verify any specific module against the CMVP validated-modules list before relying on an approval claim.",
  "algorithms": [
    {
      "name": "AES-128-GCM",
      "family": "symmetric-aead",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38D",
      "min_key_bits": 128,
      "detection_patterns": {
        "rust": ["\\bAes128Gcm\\b", "\\baes_128_gcm\\b", "AES_128_GCM"],
        "go": ["\\bcipher\\.NewGCM\\b.*\\baes\\.NewCipher\\b"],
        "python": ["AESGCM\\s*\\(.*16\\s*\\)", "algorithms\\.AES128", "\"AES-GCM\".*128"],
        "node": ["aes-128-gcm"],
        "java": ["AES_128/GCM", "\"AES/GCM/NoPadding\""],
        "csharp": ["AesGcm"],
        "regex_fallback": ["\\baes[-_]?128[-_]?gcm\\b"]
      },
      "notes": "Preferred AEAD for new code. 128-bit key acceptable for most baselines; use 256 for CNSA 2.0."
    },
    {
      "name": "AES-256-GCM",
      "family": "symmetric-aead",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38D",
      "min_key_bits": 256,
      "detection_patterns": {
        "rust": ["\\bAes256Gcm\\b", "\\baes_256_gcm\\b", "AES_256_GCM"],
        "go": ["\\bcipher\\.NewGCM\\b"],
        "python": ["AESGCM\\s*\\(.*32\\s*\\)", "algorithms\\.AES256"],
        "node": ["aes-256-gcm"],
        "java": ["\"AES/GCM/NoPadding\""],
        "regex_fallback": ["\\baes[-_]?256[-_]?gcm\\b"]
      },
      "notes": "Required for CNSA 2.0 and FedRAMP High at-rest encryption."
    },
    {
      "name": "AES-128-CCM",
      "family": "symmetric-aead",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38C",
      "detection_patterns": {
        "regex_fallback": ["\\baes[-_]?128[-_]?ccm\\b"]
      }
    },
    {
      "name": "AES-256-CCM",
      "family": "symmetric-aead",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38C",
      "detection_patterns": {
        "regex_fallback": ["\\baes[-_]?256[-_]?ccm\\b"]
      }
    },
    {
      "name": "AES-128-CBC",
      "family": "symmetric-block",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38A",
      "detection_patterns": {
        "regex_fallback": ["\\baes[-_]?128[-_]?cbc\\b"]
      },
      "notes": "Unauthenticated — pair with HMAC-SHA-256 in encrypt-then-MAC construction. Subject to padding-oracle attacks if not carefully used."
    },
    {
      "name": "AES-256-CBC",
      "family": "symmetric-block",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38A",
      "detection_patterns": {
        "regex_fallback": ["\\baes[-_]?256[-_]?cbc\\b"]
      },
      "notes": "Unauthenticated — pair with HMAC-SHA-384 or stronger."
    },
    {
      "name": "AES-KW / AES-KWP",
      "family": "key-wrap",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38F",
      "detection_patterns": {
        "regex_fallback": ["\\baes[-_]?kwp?\\b", "AES Key Wrap"]
      }
    },
    {
      "name": "AES-XTS",
      "family": "storage-encryption",
      "status": "APPROVED",
      "fips_reference": "FIPS 197; SP 800-38E",
      "detection_patterns": {
        "regex_fallback": ["\\baes[-_]?xts\\b"]
      },
      "notes": "For storage encryption only; not for general-purpose data."
    },
    {
      "name": "ChaCha20-Poly1305",
      "family": "symmetric-aead",
      "status": "DISALLOWED",
      "fips_reference": "not in FIPS 140-3 IG approved list",
      "detection_patterns": {
        "rust": ["\\bChaCha20Poly1305\\b", "\\bchacha20poly1305\\b", "\\bchacha20_poly1305\\b"],
        "go": ["chacha20poly1305\\."],
        "python": ["ChaCha20Poly1305", "ChaCha20"],
        "node": ["chacha20-poly1305"],
        "java": ["ChaCha20/Poly1305", "ChaCha20-Poly1305"],
        "regex_fallback": ["\\bchacha20[-_]?poly1305\\b"]
      },
      "remediation_id": "replace-chacha-with-aes-gcm",
      "notes": "Common in Rust/Go libraries. Replace with AES-256-GCM from a FIPS-validated module."
    },
    {
      "name": "XChaCha20-Poly1305",
      "family": "symmetric-aead",
      "status": "DISALLOWED",
      "fips_reference": "not in FIPS 140-3 IG approved list",
      "detection_patterns": {
        "regex_fallback": ["\\bxchacha20[-_]?poly1305\\b"]
      },
      "remediation_id": "replace-chacha-with-aes-gcm"
    },
    {
      "name": "3DES / TDEA",
      "family": "symmetric-block",
      "status": "DISALLOWED",
      "fips_reference": "SP 800-131A Rev 3",
      "disallowed_after": "2023-12-31",
      "detection_patterns": {
        "rust": ["\\bTripleDES\\b", "\\b3des\\b", "\\bDes3\\b"],
        "go": ["\\bdes\\.NewTripleDESCipher\\b"],
        "python": ["DES3", "TripleDES", "algorithms\\.TripleDES"],
        "java": ["\"DESede\"", "\"TripleDES\""],
        "regex_fallback": ["\\b3[-_]?des\\b", "\\btriple[-_]?des\\b"]
      },
      "remediation_id": "replace-3des-with-aes",
      "hardcoded_floor": true
    },
    {
      "name": "DES",
      "family": "symmetric-block",
      "status": "DISALLOWED",
      "fips_reference": "never approved in FIPS 140-3",
      "detection_patterns": {
        "rust": ["\\bDes::new\\b"],
        "python": ["algorithms\\.DES"],
        "java": ["\"DES\"(?!ede)"],
        "regex_fallback": ["\\bdes[_-]?cbc\\b"]
      },
      "hardcoded_floor": true
    },
    {
      "name": "RC4",
      "family": "symmetric-stream",
      "status": "DISALLOWED",
      "fips_reference": "never approved",
      "detection_patterns": {
        "regex_fallback": ["\\brc4\\b", "\\barc4\\b"]
      },
      "hardcoded_floor": true
    },
