      }
    },
    {
      "name": "SHA-1 for signing",
      "family": "hash",
      "status": "DISALLOWED",
      "fips_reference": "SP 800-131A Rev 3",
      "disallowed_after": "2013-12-31",
      "detection_patterns": {
        "rust": ["\\bSha1::", "sha1::"],
        "go": ["\\bsha1\\.New\\b", "crypto/sha1"],
        "python": ["hashlib\\.sha1\\b", "SHA1\\.new"],
        "java": ["\"SHA-1\"", "MessageDigest\\.getInstance\\(\"SHA-?1\""],
        "regex_fallback": ["\\bsha[-_]?1\\b(?![-_]?for[-_]?legacy)"]
      },
      "remediation_id": "replace-sha1-with-sha256",
      "hardcoded_floor": true,
      "notes": "Flag all uses; differentiate legacy-verify from new-generation only via human review (AST disambiguation in v0.2+)."
    },
    {
      "name": "MD5",
      "family": "hash",
      "status": "DISALLOWED",
      "fips_reference": "never approved",
      "detection_patterns": {
        "rust": ["\\bMd5\\b", "\\bmd5::\\b"],
        "go": ["\\bmd5\\.New\\b", "crypto/md5"],
        "python": ["hashlib\\.md5\\b", "MD5\\.new"],
        "java": ["\"MD5\"", "MessageDigest\\.getInstance\\(\"MD5\""],
        "node": ["createHash\\(['\"]md5['\"]\\)"],
        "regex_fallback": ["\\bmd5\\b"]
      },
      "remediation_id": "replace-md5-with-sha256",
      "hardcoded_floor": true,
      "suppression_hint": "If md5 is used for non-security integrity checks (e.g., cache-busting ETag), add inline suppression with reason=\"non-security integrity\"; but prefer BLAKE2 or xxHash for that."
    },
    {
      "name": "MD4",
      "family": "hash",
      "status": "DISALLOWED",
